#!/usr/bin/env python3
"""
vexc — Vex compiler: .vex -> C -> native binary
Usage: vexc [options] <file.vex>
  -o <out>    output binary (default: a.out)
  -S          emit C source only (don't compile)
  -O<n>       optimization level passed to gcc (default: -O2)
  -v          verbose
"""
import sys
import os
import subprocess
import tempfile
import argparse

sys.path.insert(0, os.path.dirname(__file__))
from vex import parse, typecheck, generate


def main():
    ap = argparse.ArgumentParser(prog='vexc', add_help=True)
    ap.add_argument('file')
    ap.add_argument('-o', default='a.out', metavar='OUT')
    ap.add_argument('-S', action='store_true', help='emit C only')
    ap.add_argument('-O', default='2', metavar='N')
    ap.add_argument('-v', action='store_true')
    args = ap.parse_args()

    src_path = args.file
    with open(src_path) as f:
        src = f.read()

    try:
        module = parse(src, src_path)
        tc = typecheck(module)
        c_src = generate(module, tc)
    except Exception as e:
        print(f'vexc: error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.S:
        base = os.path.splitext(src_path)[0]
        out_c = base + '.c'
        with open(out_c, 'w') as f:
            f.write(c_src)
        if args.v:
            print(f'wrote {out_c}')
        return

    # write to temp file, compile with gcc
    with tempfile.NamedTemporaryFile(suffix='.c', mode='w', delete=False) as tmp:
        tmp.write(c_src)
        tmp_path = tmp.name

    try:
        cmd = ['gcc', f'-O{args.O}', '-o', args.o, tmp_path, '-lm']
        if args.v:
            print('cc:', ' '.join(cmd))
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            print('vexc: C compilation failed:', file=sys.stderr)
            print(result.stderr, file=sys.stderr)
            # show generated C for debugging
            if args.v:
                print('--- generated C ---')
                print(c_src)
            sys.exit(1)
        if args.v:
            print(f'wrote {args.o}')
    finally:
        os.unlink(tmp_path)


if __name__ == '__main__':
    main()
