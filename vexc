#!/usr/bin/env python3
"""
vexc — Vex compiler: .vex -> C -> native binary

Usage: vexc [options] <file.vex> [file2.vex ...]
  -o <out>    output binary (default: a.out)
  -S          emit C source only (don't compile)
  -O<n>       optimization level passed to gcc (default: -O2)
  -v          verbose
  -I <dir>    add directory to Vex import search path

Multiple source files are merged into one compilation unit before
type-checking. Vex imports (import "foo.vex") are resolved relative
to the importing file and deduplicated automatically.
"""
import sys
import os
import subprocess
import tempfile
import argparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from vex import parse_files, typecheck, generate


def main():
    ap = argparse.ArgumentParser(prog='vexc', add_help=True)
    ap.add_argument('files', nargs='+', metavar='FILE')
    ap.add_argument('-o', default='a.out', metavar='OUT')
    ap.add_argument('-S', action='store_true', help='emit C only')
    ap.add_argument('-O', default='2', metavar='N')
    ap.add_argument('-v', action='store_true')
    ap.add_argument('-I', dest='include_dirs', action='append',
                    default=[], metavar='DIR')
    args = ap.parse_args()

    # Resolve any import search paths via environment so parse_file can find them
    if args.include_dirs:
        os.environ['VEX_PATH'] = ':'.join(os.path.abspath(d) for d in args.include_dirs)

    try:
        module = parse_files(args.files)
        tc = typecheck(module)
        c_src = generate(module, tc)
    except Exception as e:
        print(f'vexc: error: {e}', file=sys.stderr)
        sys.exit(1)

    if args.S:
        base = os.path.splitext(args.files[0])[0]
        out_c = base + '.c'
        with open(out_c, 'w') as f:
            f.write(c_src)
        if args.v:
            print(f'wrote {out_c}')
        return

    with tempfile.NamedTemporaryFile(suffix='.c', mode='w', delete=False) as tmp:
        tmp.write(c_src)
        tmp_path = tmp.name

    try:
        cmd = ['gcc', f'-O{args.O}',
               '-Wno-incompatible-pointer-types',
               '-Wno-int-conversion',
               '-o', args.o, tmp_path, '-lm']
        if args.v:
            print('cc:', ' '.join(cmd))
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode != 0:
            print('vexc: C compilation failed:', file=sys.stderr)
            print(result.stderr, file=sys.stderr)
            if args.v:
                print('--- generated C ---')
                print(c_src)
            sys.exit(1)
        if args.v:
            print(f'wrote {args.o}')
    finally:
        os.unlink(tmp_path)


if __name__ == '__main__':
    main()
